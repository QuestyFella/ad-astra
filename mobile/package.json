{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.18.2",
    "@react-navigation/native": "^7.3.3",
    "@react-navigation/native-stack": "^7.17.5",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.13",
    "expo-camera": "~17.0.0",
    "expo-dev-client": "~6.0.21",
    "expo-file-system": "~19.0.0",
    "expo-haptics": "~15.0.0",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.0",
    "expo-linear-gradient": "~15.0.0",
    "expo-status-bar": "~3.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "upng-js": "^2.1.0"
  },
  "devDependencies": {
    "@expo/metro-config": "^54.0.16",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "^54.0.11",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "prepare-solver-assets": "bash ../scripts/prebuild-mobile-solver.sh",
    "prestart": "npm run prepare-solver-assets",
    "preandroid": "npm run prepare-solver-assets",
    "preios": "npm run prepare-solver-assets",
    "preweb": "npm run prepare-solver-assets",
    "typecheck": "npm run prepare-solver-assets && tsc --noEmit",
    "export:web": "npm run prepare-solver-assets && npx expo export --platform web",
    "test:wasm": "npm run prepare-solver-assets && npx tsx scripts/test-wasm-solver.ts",
    "test:star-detection": "npx tsx scripts/test-star-detection.ts",
    "test:native-parse": "npx tsx scripts/test-native-parse.ts",
    "test:solver-lifecycle": "npx tsx scripts/test-solver-lifecycle.ts",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
  "private": true
}
